<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="REST Assured Suite">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="CRUD Tests">

        <classes>
            <class name="tests.CreateBookingTest"/>
            <class name="tests.GetBookingTest"/>
            <class name="tests.UpdateBookingTest"/>
            <class name="tests.PartialUpdateBookingTest"/>
            <class name="tests.DeleteBookingTest"/>
        </classes>

    </test>

    <test name="Workflow Test">

        <classes>
            <class name="tests.BookingWorkflowTest"/>
        </classes>

    </test>

</suite>